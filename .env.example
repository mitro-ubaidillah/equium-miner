# === RPC Configuration ===
# Helius recommended (free tier: 100k credits/day)
# Get key at: https://dev.helius.xyz/
RPC_URL=your_helius_rpc

# === Wallet ===
# Base58 encoded private key (from Phantom export or solana-keygen)
PRIVATE_KEY=your_base58_private_key_here

# === Jito Anti-MEV ===
# Jito block engine endpoint for bundle submission
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1
# Tip amount in SOL (minimum ~0.00001 SOL, recommended 0.0001 for priority)
JITO_TIP_LAMPORTS=100000

# === Mining Config ===
# Number of threads (default: CPU cores - 1)
THREADS=4
# Max attempts per nonce cycle before refreshing challenge
MAX_ATTEMPTS=1000
# Delay between rounds in ms (avoid rate limiting)
ROUND_DELAY_MS=500
